# ─── Cloudflare Bypass — Multi-Layer Cascade ─────────────────────────────────
# Sign up for ALL of these (all have free tiers). The cascade tries them in order.
# If your IP is clean, it goes direct (free). If blocked, it falls through to
# whichever API keys you've added. As long as one works, everything works.
#
# Layer 1 — ScraperAPI (1000 free req/month): https://scraperapi.com
SCRAPERAPI_KEY=your_key_here
#
# Layer 2 — Scrape.do (1000 free req/month): https://scrape.do
SCRAPEDO_TOKEN=your_token_here
#
# Layer 3 — WebScrapingAPI (1000 free req/month): https://webscrapingapi.com
WEBSCRAPINGAPI_KEY=your_key_here
#
# Layer 4 — ZenRows (1000 free req/month): https://zenrows.com
ZENROWS_KEY=your_key_here
#
# Layer 5 — Your existing flaskresolver on Render (fallback of last resort)
FLARESOLVERR_URL=https://flaskresolver.onrender.com

# ─── Redis (Upstash) ──────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ─── SearXNG (device search) ─────────────────────────────────────────────────
SEARXNG_URL=https://searxng-notebookcheck.onrender.com
