# ─── Cloudflare bypass ────────────────────────────────────────────────────────
# Your flaskresolver instance on Render (used when NBC returns 403)
FLARESOLVERR_URL=https://flaskresolver.onrender.com

# ─── Redis (Upstash) ──────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ─── SearXNG (device search) ─────────────────────────────────────────────────
SEARXNG_URL=https://searxng-notebookcheck.onrender.com
