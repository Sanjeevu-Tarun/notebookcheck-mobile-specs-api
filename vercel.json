{
  "version": 2,
  "regions": ["bom1"],
  "builds": [
    {
      "src": "index.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60
      }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "/index.ts" }],
  "crons": [
    {
      "path": "/api/nbc/keepalive",
      "schedule": "*/10 * * * *"
    }
  ]
}